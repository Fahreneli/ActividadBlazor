@using Tp02.Models
@page "/ListaPersona"
@code {
   
} 

<h3>ListaPersonas</h3>

<table class="table table-striped">
    <thead>
        <tr>
            <th>Id</th>
            <th>Nombre Completo</th>
            <th>Email</th>
            <th>Domicilio</th>
            <th>Fecha de Nacimiento</th>
            <th>Imagen</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var persona in personas)
        {
            <tr>
                <td>@persona.Id</td>
                <td>@persona.NombreCompleto</td>
                <td>@persona.Email</td>
                <td>@persona.Domicilio</td>
                <td>@persona.FechaNacimiento.ToShortDateString()</td>
                <td><img src="@persona.RutaImagen" alt="Imagen de @persona.NombreCompleto" width="100" /></td>
            </tr>
        }
    </tbody>
</table>
